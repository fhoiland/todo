                "9149ba78db3adb8f"
            ]
        ]
    },
    {
        "id": "cc01639a4315617b",
        "type": "function",
        "z": "b02c532bed475238",
        "name": "Rate limit DI1 24h",
        "func": "let resendMs = 24 * 60 * 60 * 1000; // 24 timer\nlet resetMs = 30 * 1000;            // 30 sekunder uten alarm\nlet now = Date.now();\n\nlet lastSent = flow.get(\"di1_last_sent\") || 0;\nlet falseSince = flow.get(\"di1_false_since\") || 0;\n\n// Hvis alarmen har vært borte lenge nok siden sist false,\n// gjør systemet klart for ny alarm\nif (falseSince > 0 && (now - falseSince) >= resetMs) {\n    flow.set(\"di1_alarm_ready\", true);\n}\n\nlet alarmReady = flow.get(\"di1_alarm_ready\");\nif (alarmReady === undefined) {\n    alarmReady = true;\n}\n\n// Alarm aktiv\nif (msg.payload === true) {\n    flow.set(\"di1_false_since\", 0);\n\n    if (alarmReady || (now - lastSent) >= resendMs) {\n        flow.set(\"di1_last_sent\", now);\n        flow.set(\"di1_alarm_ready\", false);\n        return msg;\n    }\n\n    return null;\n}\n\n// Alarm borte\nif (msg.payload === false) {\n    if (falseSince === 0) {\n        flow.set(\"di1_false_since\", now);\n    }\n\n    return null;\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
