    {
        "id": "0b5727c6ebebb9f9",
        "type": "function",
        "z": "b02c532bed475238",
        "name": "Build ntfy DI1 alarm",
        "func": "if (msg.payload !== true) {\n    return null;\n}\n\nmsg.headers = {\n    \"Title\": \"Hyttedass alarm\",\n    \"Priority\": \"high\",\n    \"Tags\": \"warning,rotating_light\"\n};\n\nmsg.payload = \"🚨💩 Alarm: Nå koker det i do-systemet\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 340,
